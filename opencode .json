{
  "$schema": "https://opencode.ai/config.json",
  "model": "or-custom/google/gemini-2.5-flash",
  "small_model": "or-custom/google/gemini-2.5-flash",
  "agent": {
    "build": {
      "model": "or-custom/google/gemini-2.5-flash"
    }
  },
  "provider": {
    "or-custom": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter Custom",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "google/gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash - Custom",
          "limit": {
            "context": 32000,
            "output": 4000
          }
        }
      }
    }
  }
}