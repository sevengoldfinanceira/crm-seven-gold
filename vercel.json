{
  "version": 2,
  "outputDirectory": ".",
  "github": {
    "silent": true
  },
  "rewrites": [
    { "source": "/api/tasks/list", "destination": "/api/tasks" },
    { "source": "/api/tasks/create", "destination": "/api/tasks" },
